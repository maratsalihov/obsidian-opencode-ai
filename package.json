{
  "name": "obsidian-opencode-ai-agent",
  "version": "1.0.0",
  "description": "AI coding agent plugin for Obsidian with file editing, agent mode, and multi-provider support",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "ai",
    "agent",
    "copilot",
    "claude",
    "openai",
    "coding"
  ],
  "author": "Marat Salikhov",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^16.11.6",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.19.0",
    "esbuild-plugin-copy": "^2.1.1",
    "obsidian": "latest",
    "tslib": "^2.6.0",
    "typescript": "^5.2.0"
  },
  "dependencies": {
    "openai": "^4.70.0",
    "@anthropic-ai/sdk": "^0.32.0",
    "ollama": "^0.5.9",
    "eventsource-parser": "^2.0.1"
  }
}
